rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: sessions
    // Document ID: auto-generated
    // Fields:
    //   - userId: string (required) - The UID of the owner
    //   - date: string (required, YYYY-MM-DD)
    //   - startTime: string (required, HH:mm)
    //   - endTime: string (required, HH:mm)
    //   - duration: number (required, positive)
    //   - mainTask: string (required, max 100 chars)
    //   - topic: string (required, max 100 chars)
    //   - createdAt: timestamp (required)
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isValidSession(data) {
      return data.userId is string && data.userId == request.auth.uid &&
             data.date is string && data.date.matches("^\\d{4}-\\d{2}-\\d{2}$") &&
             data.startTime is string && data.startTime.matches("^\\d{2}:\\d{2}$") &&
             data.endTime is string && data.endTime.matches("^\\d{2}:\\d{2}$") &&
             data.duration is number && data.duration > 0 &&
             data.mainTask is string && data.mainTask.size() > 0 && data.mainTask.size() <= 100 &&
             data.topic is string && data.topic.size() > 0 && data.topic.size() <= 100 &&
             data.createdAt is timestamp;
    }

    match /sessions/{sessionId} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated() && isValidSession(request.resource.data);
      allow update: if isAuthenticated() && isOwner(resource.data.userId) && isValidSession(request.resource.data) && request.resource.data.userId == resource.data.userId;
      allow delete: if isAuthenticated() && isOwner(resource.data.userId);
    }

    match /settings/{userId} {
      allow read: if isOwner(userId);
      allow write: if isOwner(userId) && 
                   request.resource.data.timer is map &&
                   request.resource.data.theme is map &&
                   request.resource.data.sound is map &&
                   request.resource.data.updatedAt is timestamp;
    }
    
    match /users/{userId} {
      allow read, write: if isOwner(userId);
    }
  }
}
